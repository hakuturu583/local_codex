#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
compose_file="${script_dir}/docker-compose.yml"

target_dir="."
if [[ $# -gt 0 ]]; then
  case "${1}" in
    -h|--help)
      cat <<'EOF'
Usage: local_codex [directory] [codex args...]

Examples:
  local_codex .
  local_codex ~/src/my-project
  local_codex ~/src/my-project -- --help
EOF
      exit 0
      ;;
  esac
fi

if [[ $# -gt 0 && -d "${1}" ]]; then
  target_dir="${1}"
  shift
fi

target_dir="$(cd -- "${target_dir}" && pwd)"

exec docker compose -f "${compose_file}" run --rm --service-ports \
  -v "${target_dir}:/workspace" \
  -w /workspace \
  codex-ollama codex-local "$@"
